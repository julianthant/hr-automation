UCPATH_USER_ID=your-ucsd-user-id
UCPATH_PASSWORD=your-ucsd-password
NAME=your-timekeeper-name

# Annual dates (optional — override when fiscal year rolls)
# Format matches the hardcoded defaults in src/config.ts (MM/DD/YYYY or M/D/YYYY).
# ANNUAL_DATES_END=06/30/2027
# KRONOS_DEFAULT_END_DATE=2/1/2027
# KRONOS_DEFAULT_START_DATE=1/1/2017

# SharePoint spreadsheet URLs — dashboard queue-header "Download" dropdown.
#
# The registry in src/workflows/sharepoint-download/registry.ts maps each
# dropdown option to an env var here. Unset vars render the option disabled
# with an "unset" hint; set vars save into src/data/<timestamp>-<filename>.xlsx
# on click. Add one line per spreadsheet as the registry grows.
#
# ONBOARDING_ROSTER_URL=https://ucsdcloud.sharepoint.com/.../onboarding.xlsx
