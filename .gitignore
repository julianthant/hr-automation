# Environment variables / secrets
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
venv/
.venv/

# Node
node_modules/

# IDE
.vscode/
.idea/

# Auth session state
.auth/

# Claude Code
.claude/

# Superpowers brainstorm mockups
.superpowers/

# Dashboard log
.dashboard.log

# Playwright CLI
.playwright-cli/

# Playwright MCP (snapshots, console logs)
.playwright-mcp/

# Superpowers plans / review-request scratch docs
docs/superpowers/

# Tracker data (local runtime) + ephemeral test/idempotency dirs
.tracker/
.tracker-*/

# Excel tracking files
*.xlsx

# Downloaded rosters + captured screenshots (local-only, PII-adjacent).
# Directory shells are tracked via .gitkeep so runtime writers find the targets.
src/data/*
!src/data/.gitkeep
!src/data/screenshots/
src/data/screenshots/*
!src/data/screenshots/.gitkeep

# Legacy screenshot location — kept for cleanup on older working trees.
.screenshots/

# Generated JSON Schemas (re-generated via `npm run schemas:export`)
schemas/*.schema.json

# OS
.DS_Store
Thumbs.db

# Scratch files (chat references, not meant to be committed)
/image.png
/notes.md
